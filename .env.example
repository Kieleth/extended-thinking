# AI Providers (at least one required for extraction + wisdom)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (two tiers: fast/cheap extraction, strong reasoning for wisdom)
# Extraction runs per batch of ~20 chunks. Wisdom runs once per insight.
# Defaults below use Haiku + Opus. Override to use Sonnet, GPT-4o, GPT-5, etc.
# ET_EXTRACTION_PROVIDER / ET_WISDOM_PROVIDER pick which provider to use;
# leave empty to auto-pick from whichever API key is configured.
ET_EXTRACTION_PROVIDER=
ET_EXTRACTION_MODEL=claude-haiku-4-5-20251001
ET_WISDOM_PROVIDER=
ET_WISDOM_MODEL=claude-opus-4-6

# Silk persistent storage
SILK_DATA_DIR=./data/silk

# Auth (leave AUTH_USERNAME empty to disable auth in dev)
AUTH_SECRET=change-me-to-a-random-string
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
